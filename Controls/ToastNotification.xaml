<UserControl x:Class="AppsTime.Controls.ToastNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="75" Width="390"
             Opacity="0">

	<Border x:Name="ToastBorder"
            Background="#FF2D2D30"
            BorderBrush="#FF505050"
            BorderThickness="1"
            CornerRadius="8"
            Padding="15,12">
		<Border.Effect>
			<DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.4"/>
		</Border.Effect>

		<Grid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="Auto"/>
			</Grid.ColumnDefinitions>

			<!-- Иконка -->
			<TextBlock x:Name="ToastIcon"
                       Grid.Column="0"
                       Text="ℹ️"
                       FontSize="20"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>

			<!-- Контент -->
			<StackPanel Grid.Column="1" VerticalAlignment="Center">
				<TextBlock x:Name="ToastTitle"
                           Text="Заголовок"
                           Foreground="#FFFFFFFF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Margin="0,0,0,2"/>
				<TextBlock x:Name="ToastMessage"
                           Text="Текст уведомления"
                           Foreground="#FFB0B0B0"
                           FontSize="10"
                           TextWrapping="Wrap"/>
			</StackPanel>

			<!-- Кнопка закрытия -->
			<Button Grid.Column="2"
                    Content="✕"
                    Width="20" Height="20"
                    Padding="0"
                    Click="ButtonClose_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="#FF808080"
                    Cursor="Hand"
                    VerticalAlignment="Top"
                    FontSize="12">
				<Button.Style>
					<Style TargetType="Button">
						<Style.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Foreground" Value="#FFFFFFFF"/>
							</Trigger>
						</Style.Triggers>
					</Style>
				</Button.Style>
			</Button>
		</Grid>
	</Border>
</UserControl>